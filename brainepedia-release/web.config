<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Tell IIS to hand ALL requests to iisnode → server.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Route everything through server.js (handles static + SPA fallback) -->
        <rule name="all" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Surface Node.js errors instead of swallowing them -->
    <httpErrors existingResponse="PassThrough" />

    <iisnode
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

  </system.webServer>
</configuration>
